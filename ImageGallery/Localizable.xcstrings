    "databaseInitReset": {
      "comment": "V6.12.17: V Copy.databaseInitReset → 重置数据库（删除本地所有数据）",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset Database (delete all local data)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重置数据库（删除本地所有数据）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重置資料庫（刪除本地所有數據）"
          }
        }
      }
    },
    "databaseInitResetConfirm": {
      "comment": "V6.12.17: V Copy.databaseInitResetConfirm → 重置会永久删除所有照片记录、文件夹、标签和回收站。导入的原图文件不会删除（仍在 Finder 里）。确定要继续吗？",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset will permanently delete all photo records, folders, tags, and Recycle Bin. Original imported photos on disk will not be deleted. Continue?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重置会永久删除所有照片记录、文件夹、标签和回收站。导入的原图文件不会删除（仍在 Finder 里）。确定要继续吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重置會永久刪除所有照片記錄、資料夾、標籤和垃圾桶。匯入的原圖檔案不會刪除（仍在 Finder 裡）。確定要继续吗？"
          }
        }
      }
    },
