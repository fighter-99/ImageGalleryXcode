    "storageError": {
      "extractionState": "manual",
      "comment": "V6.12.17: V Copy.storageError → 无法保存图片到图库。请检查磁盘空间，或在「系统设置 → 隐私与安全 → 完整磁盘访问权限」中授权 ImageGaller...",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cannot save photos to library. Check disk space or grant Full Disk Access in System Settings → Privacy & Security → Full Disk Access to ImageGallery, then retry."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "无法保存图片到图库。请检查磁盘空间，或在「系统设置 → 隐私与安全 → 完整磁盘访问权限」中授权 ImageGallery，然后重试。"
          }
        }
      }
    },
